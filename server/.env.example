# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/ai-resume-builder

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── AI / Gemini ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── JWT ──────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_SECRET=your_access_token_secret_min_32_chars
ACCESS_TOKEN_EXPIRY=15m

REFRESH_TOKEN_SECRET=your_refresh_token_secret_min_32_chars
REFRESH_TOKEN_EXPIRY=7d

# ─── Password Reset ────────────────────────────────────────────────────────────
# Separate secret for reset tokens — keeps them isolated from access tokens.
# Generate with: node -e "require('crypto').randomBytes(32).toString('hex')"
RESET_TOKEN_SECRET=your_reset_token_secret_min_32_chars

# ─── Email / SMTP ──────────────────────────────────────────────────────────────
# Gmail:   SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_SECURE=false
# Resend:  SMTP_HOST=smtp.resend.com SMTP_PORT=465  SMTP_SECURE=true
# Mailtrap (dev): SMTP_HOST=sandbox.smtp.mailtrap.io SMTP_PORT=2525
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password_here
